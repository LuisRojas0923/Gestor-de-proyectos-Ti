# =============================================================================
# Gestor de Proyectos TI - Variables de entorno (ejemplo)
# =============================================================================
# Copia este archivo a `.env` en la raiz del repo y rellena los valores
# sensibles. El `.env` real NO debe commitearse (esta en .gitignore).
#
# Cualquier valor que falte cae al default de la app. Los defaults son
# seguros para desarrollo local; en produccion TODOS los secretos deben
# estar definidos.
# =============================================================================

# --- Base de datos principal --------------------------------------------------
DB_USER=user
DB_PASS=pass
DB_NAME=project_manager
DB_PORT=5432
DB_SCHEMA_OWNER_ROLE=gestor_schema_owner
DB_MIGRATION_USER=gestor_migrador
# Inyectar desde secret manager; no compartir con el servicio backend.
DB_MIGRATION_PASS=
DB_RUNTIME_USER=gestor_runtime
DB_RUNTIME_PASS=

# Capacidad independiente de la credencial runtime. Generar con
# `openssl rand -hex 32` y montar el mismo archivo en migrate y backend.
RBAC_ADMIN_CAPABILITY_FILE=./secrets/rbac_admin_capability.key

# El job `migrate` debe recibir MIGRATION_DATABASE_URL desde el entorno de
# despliegue o secret manager, nunca desde este archivo compartido con runtime.
# El rol LOGIN migrador debe poder SET ROLE al owner NOLOGIN indicado aqui.
MIGRATION_SCHEMA_OWNER_ROLE=gestor_schema_owner

# Bootstrap de un solo uso. El archivo debe contener una clave aleatoria de
# al menos 32 caracteres y se monta solo en el job migrate.
ADMIN_BOOTSTRAP_PASSWORD_FILE=./secrets/admin_bootstrap_password
ADMIN_BOOTSTRAP_CEDULA=
ADMIN_BOOTSTRAP_NOMBRE=Administrador inicial

# --- ERP (opcional, depende de despliegue) -----------------------------------
ERP_DATABASE_URL=postgresql://user:pass@localhost:5432/erp_db
# Credencial separada con permisos CONNECT + SELECT para sincronizar perfiles.
ERP_READ_DATABASE_URL=postgresql://erp_read:pass@localhost:5432/solidpruebas3
ERP_READ_EXPECTED_DATABASE=solidpruebas3

# --- JWT ---------------------------------------------------------------------
# En produccion: rotar con `openssl rand -hex 64`. Minimo 32 bytes.
JWT_SECRET_KEY=cambiar-en-produccion-usar-openssl-rand
ALGORITHM=HS256
JWT_TOKEN_EXPIRE_MINUTES=60
PORTAL_PENDING_PWD=
JIT_AUTO_APROBAR=false
VERIFY_ADMIN_RATE_LIMIT=5/5minute
RATE_LIMIT_LOGIN=5/minute;20/hour
RATE_LIMIT_SETUP_PASSWORD=30/hour
RATE_LIMIT_FORGOT_PASSWORD=3/hour
RATE_LIMIT_RESET_PASSWORD=5/hour
RATE_LIMIT_REGISTRO=5/hour
RATE_LIMIT_PASSWORD_STATUS=5/minute
RATE_LIMIT_LOGOUT=10/minute
RATE_LIMIT_REFRESH=20/hour
RATE_LIMIT_SYNC_USUARIO_ERP=10/minute
RATE_LIMIT_PREVIEW_USUARIOS_ERP=2/hour
RATE_LIMIT_APPLY_USUARIOS_ERP=1/hour
LOCKOUT_UMBRAL_FALLOS=10
LOCKOUT_VENTANA_MINUTOS=15
LOCKOUT_DURACION_MINUTOS=15

# --- Redis (rate limiter storage) --------------------------------------------
# Password del Redis. Se usa tambien como `requirepass` en el contenedor.
# En produccion: rotar y guardar en secrets manager.
REDIS_PASSWORD=change-me-redis-password

# Lista separada por comas de IPs de proxies en los que se confía el header
# X-Forwarded-For. VACIO = no se confía en ningún proxy (cae al IP de la
# conexion TCP). PROHIBIDO usar "*".
# En docker con nginx delante, la IP del contenedor nginx (e.g., 172.18.0.2).
TRUSTED_PROXY_IPS=

# --- Sync externo / frontend -------------------------------------------------
SYNC_EXTERNAL_URL=http://localhost:8099/sync
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
HOSTVEREMAIL=http://portalservicios.refridcol.com

# --- Integraciones opcionales ------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_SSL=true
NOTION_API_KEY=
NOTION_DATABASE_ID=
CALENDARIFIC_API_KEY=
LIBRANZA_OCCIDENTE_PASSWORD=
BIOMETRIA_MAX_IMAGE_BYTES=5242880

# --- Entorno -----------------------------------------------------------------
ENVIRONMENT=development

# --- Almacenamiento de adjuntos ----------------------------------------------
STORAGE_PATH=/app/storage/attachments
# Rango admitido por configuración: 1 a 100 MB por archivo.
STORAGE_MAX_SIZE_MB=25
RATE_LIMIT_ACTIVIDAD_ARCHIVO=20/hour
