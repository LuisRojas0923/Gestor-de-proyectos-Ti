# =============================================================================
# Gestor de Proyectos TI - Variables de entorno (ejemplo)
# =============================================================================
# Copia este archivo a `.env` en la raiz del repo y rellena los valores
# sensibles. El `.env` real NO debe commitearse (esta en .gitignore).
#
# Cualquier valor que falte cae al default de la app. Los defaults son
# seguros para desarrollo local; en produccion TODOS los secretos deben
# estar definidos.
# =============================================================================

# --- Base de datos principal --------------------------------------------------
DB_USER=user
DB_PASS=pass
DB_NAME=project_manager
DB_PORT=5432

# --- ERP (opcional, depende de despliegue) -----------------------------------
ERP_DATABASE_URL=postgresql://user:pass@localhost:5432/erp_db

# --- JWT ---------------------------------------------------------------------
# En produccion: rotar con `openssl rand -hex 64`. Minimo 32 bytes.
JWT_SECRET_KEY=cambiar-en-produccion-usar-openssl-rand
ALGORITHM=HS256
JWT_TOKEN_EXPIRE_MINUTES=60

# --- Redis (rate limiter storage) --------------------------------------------
# Password del Redis. Se usa tambien como `requirepass` en el contenedor.
# En produccion: rotar y guardar en secrets manager.
REDIS_PASSWORD=change-me-redis-password

# Lista separada por comas de IPs de proxies en los que se confía el header
# X-Forwarded-For. VACIO = no se confía en ningún proxy (cae al IP de la
# conexion TCP). PROHIBIDO usar "*".
# En docker con nginx delante, la IP del contenedor nginx (e.g., 172.18.0.2).
TRUSTED_PROXY_IPS=

# --- Sync externo / frontend -------------------------------------------------
SYNC_EXTERNAL_URL=http://localhost:8099/sync
FRONTEND_HOST=localhost

# --- Entorno -----------------------------------------------------------------
# Admite "development" / "desarrollo", "production" / "produccion", "testing" / "tests"
ENVIRONMENT=development

# --- Orígenes permitidos (CORS y WebSockets) --------------------------------
# CORS: Lista separada por comas de orígenes HTTP/HTTPS permitidos para llamadas REST.
CORS_ORIGENES_PERMITIDOS=*

# WebSockets: Lista separada por comas de orígenes HTTP/HTTPS permitidos para conexiones WebSocket.
# En desarrollo: si está vacío, por defecto se permiten localhost:5173, 127.0.0.1:5173, localhost:8000, etc.
# En producción: si está vacío, la política falla cerrada (rechaza todas las conexiones WS por seguridad).
# Ejemplo en producción: WS_ORIGENES_PERMITIDOS=https://gestor.empresa.com,https://servicios.empresa.com
WS_ORIGENES_PERMITIDOS=

# --- Almacenamiento de adjuntos ----------------------------------------------
STORAGE_PATH=/app/storage/attachments
# Rango admitido por configuración: 1 a 100 MB por archivo.
STORAGE_MAX_SIZE_MB=25
RATE_LIMIT_ACTIVIDAD_ARCHIVO=20/hour
